[sub_resource type="Resource" id="line_1"]
script = ExtResource("2_line")
character_name = "Green Karim"
text = "Kheb toch al gezegd dat ik m'n bek dicht doe.. Jesus."
voice_pitch = 0.8

[sub_resource type="Resource" id="line_2"]
script = ExtResource("2_line")
character_name = "Green Karim"
text = "Oh, wat hoor ik daar? Je hebt mijn broer ontmoet? Ah, dus je moest de groeten doen. Doe vooral niet de groeten terug, kankernerd dat het is, mijn vader had zich in zijn eigen graf omgedraait."
voice_pitch = 0.8

[resource]
script = ExtResource("1_seq")
description = "Green Karim reformed + extra line about Orange Karim"
one_shot = false
lines = Array[ExtResource("2_line")]([SubResource("line_1"), SubResource("line_2")])
