[sub_resource type="Resource" id="line_2"]
script = ExtResource("2_line")
character_name = "Orange Karim"
text = "Een ding hier heet 'Windows XP' geen idee wat het is en hoe het werkt, maar dat is juist het leuke!"
voice_pitch = 1.1

[sub_resource type="Resource" id="line_3"]
script = ExtResource("2_line")
character_name = "Orange Karim"
text = "Ik heb nog zoveel dingen uit het verleden om te ontdekken, de toekomst zit in het verleden!"
voice_pitch = 1.1

[resource]
script = ExtResource("1_seq")
