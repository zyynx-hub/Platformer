[sub_resource type="Resource" id="line_2"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Deze is te vinden na een driekoppige entiteit te ontwaken en zijn ware aard naar voren te laten komen."
voice_pitch = 0.15

[sub_resource type="Resource" id="line_3"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Ook zie ik de kleur paars, waar het begint en waar het eindigt."
voice_pitch = 0.15

[resource]
