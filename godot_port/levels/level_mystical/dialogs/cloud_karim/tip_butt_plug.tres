[sub_resource type="Resource" id="line_1"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Het meest traditionale object, natuurlijk."
voice_pitch = 0.15

[sub_resource type="Resource" id="line_2"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Een manier van gebruik, een doel, een concrete bestemming."
voice_pitch = 0.15

[sub_resource type="Resource" id="line_3"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Het gefluister in de wolken toont mij een eenzame man gekleurd in oranje, alleen interesse in de toekomst en wat het te bieden heeft."
voice_pitch = 0.15

[sub_resource type="Resource" id="line_4"]
script = ExtResource("2_line")
character_name = "Wolk der Karim"
text = "Aantonen dat er altijd meer is zal jou tot het object leiden."
voice_pitch = 0.15

[resource]
script = ExtResource("1_seq")
description = "Cloud Karim tip — Butt Plug (Orange Karim quest)"
one_shot = false
